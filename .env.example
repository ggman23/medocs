# Fuseau horaire utilisé pour calculer « aujourd'hui » et « maintenant ».
APP_TZ=Europe/Paris

# Emplacement de la base de données SQLite.
# En local : ./data/medocs.db — en Docker : /data/medocs.db (volume persistant).
DATABASE_PATH=./data/medocs.db

# Mot de passe d'accès (FORTEMENT recommandé avant de publier l'app sur Internet).
# S'il est vide, l'application est ouverte (pratique en local).
# APP_PASSWORD=choisissez-un-mot-de-passe-solide
